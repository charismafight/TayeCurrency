<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:uranium="http://schemas.enisn-projects.io/dotnet/maui/uraniumui"
             xmlns:viewmodel="clr-namespace:Taye.MAUI.ViewModels"
             xmlns:converters="clr-namespace:Taye.MAUI.Converters"
             x:Class="Taye.MAUI.MainPage"
             Title="李太一的货币详情"
             BackgroundColor="#F5F5F5"
             x:DataType="viewmodel:StarRecordViewModel">

    <ContentPage.Resources>
        <converters:TypeColorConverter x:Key="TypeColorConverter" />
        <converters:StarColorConverter x:Key="StarColorConverter" />
        <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
        <converters:IsNotNullConverter x:Key="IsNotNullConverter" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto, *, Auto">

        <!-- 顶部统计区（可滚动） -->
        <ScrollView Grid.Row="0" MaximumHeightRequest="280">
            <VerticalStackLayout Spacing="12" Padding="16">

                <!-- 剩余星星卡片（原生 Frame 模拟卡片） -->
                <Frame BackgroundColor="#512BD4"
                       CornerRadius="24"
                       Padding="20"
                       HasShadow="False">
                    <Grid ColumnDefinitions="*, Auto">
                        <VerticalStackLayout>
                            <Label Text="当前星星"
                                   TextColor="White"
                                   FontSize="14"
                                   Opacity="0.9" />
                            <Label Text="{Binding Statistics.CurrentBalance}"
                                   TextColor="White"
                                   FontSize="48"
                                   FontAttributes="Bold" />
                        </VerticalStackLayout>
                        <Label Text="⭐"
                               Grid.Column="1"
                               FontSize="48"
                               TextColor="White"
                               VerticalOptions="Center" />
                    </Grid>
                </Frame>



                <!-- 筛选器（原生 Picker） -->
                <Picker x:Name="FilterPicker"
                        Title="筛选"
                        Margin="0,4,0,0"
                        BackgroundColor="White"
                        SelectedIndex="0">
                    <Picker.Items>
                        <x:String>全部</x:String>
                        <x:String>获得</x:String>
                        <x:String>消费</x:String>
                    </Picker.Items>
                </Picker>

            </VerticalStackLayout>
        </ScrollView>

        <!-- 记录列表 -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Records}"
                        IsVisible="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}"
                        SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="12,6,12,6"
                           CornerRadius="16"
                           Padding="16"
                           BackgroundColor="White"
                           HasShadow="False">
                        <Grid ColumnDefinitions="Auto, *, Auto">
                            <!-- 星星图标背景 -->
                            <Frame Grid.Column="0"
                                   CornerRadius="28"
                                   BackgroundColor="{Binding Type, Converter={StaticResource TypeColorConverter}}"
                                   WidthRequest="56"
                                   HeightRequest="56"
                                   Padding="0"
                                   HasShadow="False">
                                <Label Text="⭐"
                                       FontSize="28"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Frame>

                            <!-- 内容 -->
                            <VerticalStackLayout Grid.Column="1" Margin="16,0">
                                <Label Text="{Binding Reason}"
                                       FontSize="16"
                                       FontAttributes="Bold" />
                                <Label Text="{Binding DisplayDate}"
                                       FontSize="12"
                                       TextColor="Gray" />
                                <Label Text="{Binding Notes}"
                                       FontSize="12"
                                       TextColor="Gray"
                                       IsVisible="{Binding Notes, Converter={StaticResource IsNotNullConverter}}" />
                            </VerticalStackLayout>

                            <!-- 星星数量 -->
                            <Label Grid.Column="2"
                                   Text="{Binding DisplayStar}"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   TextColor="{Binding Type, Converter={StaticResource StarColorConverter}}"
                                   VerticalOptions="Center" />
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- 加载中遮罩 -->
        <Grid Grid.RowSpan="3"
              IsVisible="{Binding IsLoading}"
              BackgroundColor="#80FFFFFF">
            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               Color="#512BD4"
                               Scale="1.5" />
        </Grid>

        <!-- 浮动添加按钮 -->
        <Grid Grid.Row="2"
              Padding="16,0,16,24"
              IsVisible="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}">
            <!-- 这里可以使用 UraniumUI 的 FloatingActionButton 或者原生按钮 -->
            <Button Text="+"
                    BackgroundColor="#512BD4"
                    TextColor="White"
                    FontSize="24"
                    WidthRequest="56"
                    HeightRequest="56"
                    CornerRadius="28"
                    Command="{Binding AddRecordCommand}"
                    HorizontalOptions="End"
                    VerticalOptions="Center" />
        </Grid>

    </Grid>

</ContentPage>
